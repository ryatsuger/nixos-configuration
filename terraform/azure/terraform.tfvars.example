# Copy to terraform.tfvars and fill in. terraform.tfvars is gitignored.

subscription_id = "00000000-0000-0000-0000-000000000000"

# Path to the fixed-size VHD built from the flake:
#   nix build .#nixosConfigurations.azure.config.system.build.azureImage
#   ls result/   # -> nixos-image-azure-*.vhd
vhd_local_path = "../../result/nixos.vhd"

# Should match the ed25519 key baked into local.nix
admin_ssh_public_key = "ssh-ed25519 AAAA... ruiyangsmacnixos"

# Lock SSH down to your IP, e.g. "203.0.113.4/32"
allowed_ssh_cidr = "0.0.0.0/0"

# location  = "koreacentral"
# vm_size   = "Standard_D16ads_v5"
